<!DOCTYPE html>
<html lang="en">
<head> 
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wedding Invitation - Rahul & Priya</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Great+Vibes&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Lato', sans-serif;
      background: #fff5f5;
      color: #4a4a4a;
      overflow-x: hidden;
    }

    /* --- HEADER / TABS --- */
    header {
      position: fixed;
      top: 0;
      width: 100%;
      background: linear-gradient(135deg, #fff, #ffe8e8);
      box-shadow: 0 4px 20px rgba(185, 123, 93, 0.15);
      z-index: 1000;
      padding: 10px 0;
    }

    .nav-container {
      display: flex;
      justify-content: center;
      gap: 5px;
      flex-wrap: wrap;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 10px;
    }

    .nav-tab {
      padding: 10px 20px;
      border: none;
      background: transparent;
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      color: #8b5e5e;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.3s ease;
    }

    .nav-tab:hover, .nav-tab.active {
      color: #b8835b;
      border-bottom: 2px solid #b8835b;
    }

    /* --- SECTIONS --- */
    .tab-content {
      display: none;
      padding-top: 80px;
      min-height: 100vh;
      animation: fadeIn 0.5s ease-in;
    }

    .tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* --- HERO SECTION --- */
    .hero {
      background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)),
                  linear-gradient(135deg, #f9c5a1, #e8a5b8, #c8b6e6);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px 20px;
    }

    .hero-content {
      background: rgba(255,255,255,0.95);
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      max-width: 800px;
      width: 100%;
    }

    .wedding-title {
      font-family: 'Great Vibes', cursive;
      font-size: 3.5rem;
      color: #b8835b;
      margin-bottom: 10px;
    }

    .wedding-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: #8b5e5e;
      margin-bottom: 30px;
    }

    .couple-container {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      margin: 30px 0;
    }

    .photo-frame {
      width: 180px;
      height: 180px;
      border: 4px solid #e8c4a8;
      border-radius: 50%;
      overflow: hidden;
      position: relative;
      background: #f9e8d8;
      box-shadow: 0 5px 15px rgba(185, 123, 93, 0.2);
    }

    .photo-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #b8835b;
      font-size: 14px;
      background: linear-gradient(135deg, #f9e8d8, #f5d5b8);
      cursor: pointer;
    }

    .and-symbol {
      font-family: 'Great Vibes', cursive;
      font-size: 3rem;
      color: #d4a373;
    }

    .couple-name {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: #4a4a4a;
    }

    .wedding-date {
      font-size: 1.5rem;
      color: #b8835b;
      margin: 20px 0;
      font-weight: 700;
    }

    .wedding-venue-preview {
      font-size: 1.1rem;
      color: #8b5e5e;
      margin-bottom: 20px;
    }

    .countdown {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin: 20px 0;
      flex-wrap: wrap;
    }

    .countdown-item {
      background: #fff;
      padding: 15px 20px;
      border-radius: 10px;
      box-shadow: 0 3px 10px rgba(0,0,0,0.1);
      min-width: 80px;
    }

    .countdown-item span {
      display: block;
      font-size: 1.8rem;
      font-weight: 700;
      color: #b8835b;
    }

    .countdown-item label {
      font-size: 0.8rem;
      color: #8b5e5e;
      text-transform: uppercase;
    }

    /* --- CONTENT SECTIONS --- */
    .section {
      padding: 40px 20px;
      max-width: 900px;
      margin: 0 auto;
    }

    .section-title {
      font-family: 'Great Vibes', cursive;
      font-size: 3rem;
      color: #b8835b;
      text-align: center;
      margin-bottom: 30px;
    }

    .section-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: #8b5e5e;
      text-align: center;
      margin-bottom: 30px;
    }

    .card {
      background: white;
      border-radius: 15px;
      padding: 30px;
      margin: 20px 0;
      box-shadow: 0 5px 20px rgba(0,0,0,0.08);
      border-left: 4px solid #e8c4a8;
    }

    .card h3 {
      font-family: 'Playfair Display', serif;
      color: #b8835b;
      margin-bottom: 15px;
      font-size: 1.4rem;
    }

    .card p, .card li {
      line-height: 1.6;
      color: #6a6a6a;
      margin-bottom: 10px;
    }

    .card ul {
      padding-left: 20px;
    }

    /* --- VENUE SECTION --- */
    .venue-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin: 20px 0;
    }

    .venue-card {
      background: white;
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 5px 20px rgba(0,0,0,0.08);
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .venue-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .venue-image {
      width: 100%;
      height: 180px;
      background: linear-gradient(135deg, #f5d5b8, #f9c5a1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #b8835b;
      font-size: 16px;
    }

    .venue-info {
      padding: 20px;
    }

    .venue-info h3 {
      font-family: 'Playfair Display', serif;
      color: #b8835b;
      margin-bottom: 10px;
    }

    .venue-info p {
      color: #6a6a6a;
      margin-bottom: 5px;
    }

    .venue-link {
      display: inline-block;
      margin-top: 10px;
      padding: 10px 20px;
      background: linear-gradient(135deg, #b8835b, #e8a5b8);
      color: white;
      text-decoration: none;
      border-radius: 25px;
      font-weight: 700;
      transition: all 0.3s ease;
    }

    .venue-link:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 15px rgba(185, 123, 93, 0.3);
    }

    /* --- HALDI SECTION --- */
    .haldi-container {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      justify-content: center;
      margin: 20px 0;
    }

    .haldi-card {
      background: linear-gradient(135deg, #fff9e6, #fff5d5);
      border-radius: 15px;
      padding: 30px;
      text-align: center;
      flex: 1;
      min-width: 250px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.08);
      border: 2px solid #f5d5b8;
    }

    .haldi-card h3 {
      font-family: 'Playfair Display', serif;
      color: #d4a373;
      margin-bottom: 15px;
      font-size: 1.4rem;
    }

    .haldi-icon {
      font-size: 3rem;
      margin-bottom: 15px;
    }

    /* --- RSVP FORM --- */
    .rsvp-form {
      background: white;
      padding: 30px;
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.08);
      max-width: 600px;
      margin: 0 auto;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      margin-bottom: 5px;
      font-weight: 700;
      color: #8b5e5e;
    }

    .form-group input, .form-group textarea, .form-group select {
      width: 100%;
      padding: 12px;
      border: 1px solid #e8c4a8;
      border-radius: 8px;
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      transition: border-color 0.3s ease;
    }

    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      outline: none;
      border-color: #b8835b;
    }

    .submit-btn {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #b8835b, #d4a373);
      color: white;
      border: none;
      border-radius: 25px;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .submit-btn:hover {
      transform: scale(1.02);
      box-shadow: 0 5px 15px rgba(185, 123, 93, 0.3);
    }

    /* --- GALLERY --- */
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin: 20px 0;
    }

    .gallery-item {
      width: 100%;
      height: 200px;
      background: linear-gradient(135deg, #f5d5b8, #f9c5a1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #b8835b;
      overflow: hidden;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* --- FOOTER --- */
    footer {
      background: linear-gradient(135deg, #b8835b, #d4a373);
      color: white;
      text-align: center;
      padding: 30px 20px;
      margin-top: 50px;
    }

    footer p {
      margin: 10px 0;
      font-size: 1.1rem;
    }

    .social-links {
      margin-top: 15px;
    }

    .social-links a {
      color: white;
      margin: 0 10px;
      text-decoration: none;
      font-size: 1.2rem;
    }

    /* --- DECORATIONS --- */
    .floral-border {
      height: 50px;
      background: linear-gradient(135deg, #f9c5a1, #e8a5b8, #c8b6e6);
      margin: 0;
    }

    .divider {
      width: 100px;
      height: 2px;
      background: #e8c4a8;
      margin: 20px auto;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 768px) {
      .wedding-title { font-size: 2.5rem; }
      .couple-container { flex-direction: column; }
      .photo-frame { width: 140px; height: 140px; }
      .countdown-item { padding: 10px 15px; min-width: 70px; }
      .countdown-item span { font-size: 1.5rem; }
      .section-title { font-size: 2.5rem; }
      .nav-tab { padding: 8px 12px; font-size: 12px; }
    }
  </style>
</head>
